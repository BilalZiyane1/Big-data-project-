NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/fashion_hub
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
STRIPE_SECRET_KEY=
PAYMENT_MODE=mock
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@fashionhub.com
ADMIN_PASSWORD=Admin1234
LOG_LEVEL=info
LOG_SLOW_REQUEST_THRESHOLD_MS=1000
LOG_CAPTURE_REQUEST_BODY=true
LOG_CAPTURE_RESPONSE_BODY=true
LOG_SYSTEM_METRICS_INTERVAL_MS=60000
LOG_MONGOOSE_DEBUG=false
LOG_ENABLE_STDOUT=true
LOG_ENABLE_FILES=true
LOG_FILE_DIR=logs
LOG_FILE_USE_UTC=false
LOG_FILE_LEVEL=trace
LOG_ERROR_FILE_LEVEL=warn
CLIENT_LOG_BATCH_MAX=50
CLIENT_LOG_EVENT_MAX_BYTES=32768
LOG_MAX_STRING_LENGTH=500
LOG_MAX_ARRAY_LENGTH=25
LOG_MAX_OBJECT_KEYS=50
LOG_MAX_DEPTH=6
